# ============================================================
#  Whitelist — only the curated, essential project is tracked.
#  Everything else (old / experimental code, raw & intermediate
#  data, logs, caches, heavy videos) stays local and untracked.
# ============================================================
/*
!/.gitignore
!/README.md
!/LICENSE
!/src/
!/models/
!/dataset/
!/figures/
!/media/

# generic noise (any level)
__pycache__/
*.pyc
*.pyo
~$*
.DS_Store
.ipynb_checkpoints/
